<UserControl x:Class="LibraryTrackerApp.View.ReturnBook"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 mc:Ignorable="d"
 d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="White" Margin="20">

        <!-- Page Layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock
            Grid.Row="0"
            Text="Return Book"
            FontSize="26"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <!-- Form Area -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Member ID -->
            <TextBlock Text="Member ID"
                       Grid.Row="0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Grid.Row="0"
                     Grid.Column="1"
                     Margin="5"
                     Height="30"/>

            <!-- Member Name -->
            <TextBlock Text="Member Name"
                       Grid.Row="1"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="5"
                     Height="30"
                     IsReadOnly="True"/>

            <!-- Book ID -->
            <TextBlock Text="Book ID"
                       Grid.Row="2"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Margin="5"
                     Height="30"/>

            <!-- Book Name -->
            <TextBlock Text="Book Name"
                       Grid.Row="3"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Grid.Row="3"
                     Grid.Column="1"
                     Margin="5"
                     Height="30"
                     IsReadOnly="True"/>

            <!-- Issue Date -->
            <TextBlock Text="Issue Date"
                       Grid.Row="4"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <DatePicker Grid.Row="4"
                        Grid.Column="1"
                        Margin="5"/>

            <!-- Due Date -->
            <TextBlock Text="Due Date"
                       Grid.Row="5"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <DatePicker Grid.Row="5"
                        Grid.Column="1"
                        Margin="5"/>

            <!-- Return Date -->
            <TextBlock Text="Return Date"
                       Grid.Row="6"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <DatePicker Grid.Row="6"
                        Grid.Column="1"
                        Margin="5"/>

            <!-- Fine -->
            <TextBlock Text="Fine"
                       Grid.Row="7"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox Grid.Row="7"
                     Grid.Column="1"
                     Margin="5"
                     Height="30"
                     IsReadOnly="True"/>

            <!-- Button -->
            <Button Grid.Row="8"
                    Grid.Column="1"
                    Content="Return Book"
                    Width="150"
                    Height="35"
                    Margin="5"
                    HorizontalAlignment="Left"/>

        </Grid>

    </Grid>
</UserControl>