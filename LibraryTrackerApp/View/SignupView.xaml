<Window x:Class="LibraryTrackerApp.View.SignupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryTrackerApp.View"
        mc:Ignorable="d"
        Title="SignupView" Height="650" Width="500"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Button-->
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="40" />

            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                           
                            >
                            <ContentPresenter 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                />
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <!-- Ismouseover-->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <!-- PressEffect -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform"  >
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
           
            
        </Style>
        
        
        <!-- TextBox-->
        <Style TargetType="TextBox" x:Key="PrimaryTextBoxStyle">
            
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Height" Value="35"/>


            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                          x:Name="border"
                            Background="White"
                            BorderBrush="#D1D5D8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="9"
                            >
                            <ScrollViewer x:Name="PART_ContentHouse"/>
                            

                        </Border>
                        <ControlTemplate.Triggers >
                            <!-- Focus -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border"
                                    Property="BorderBrush"
                                    Value="#2563EB"/>
                                <Setter TargetName="border"
                                    Property="BorderThickness"
                                    Value="2"/>
                            </Trigger> 
                            
                        </ControlTemplate.Triggers>
                        
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB" />
                    <Setter Property="BorderThickness" Value="1" />

                </Trigger>
                
            </Style.Triggers>
            
            
        </Style>
    </Window.Resources>
    <Grid>
        <Border
            Width="380"
            CornerRadius="20"
            BorderBrush="#E5E7EB"
            Padding="30"
            Margin="0,5,0,20"
            BorderThickness = "1"
            
            >
          
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    
                    <GradientStop 
                        Color="#FFFFFF" Offset="0"/>
                    <GradientStop 
                        Color="#F9FAFB" Offset="1"/>

                </LinearGradientBrush>
                
            </Border.Background>
            
            <Border.Effect>
                <DropShadowEffect 
          ShadowDepth="3"
          Opacity="0.25"
          BlurRadius="25"
          />

            </Border.Effect>

            <Grid>
                <StackPanel>
                <!-- Title-->
                <TextBlock
                    Text="Welcome Register"
                    FontWeight="Bold"
                    FontSize="20"                  
                    Padding="5" 
                    TextAlignment="Center"
                    Foreground="White"
                    Margin="0,5,0,20"
                    >
                   
                    <TextBlock.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>

                        </LinearGradientBrush>
                    </TextBlock.Background>
                </TextBlock>
                <!-- FullName-->
                    <TextBlock
                        Text="FullName"
                        Margin="0,5,0,10"
                        FontWeight="SemiBold"
                        FontSize="18"
                        
                        />
                    <TextBox 
                       Style="{StaticResource PrimaryTextBoxStyle}"
                        />

                    <!-- UserId-->
                    <TextBlock
                        Text="UserId"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,5,0,10"                                                                           
                            />
                    <TextBox 
                        Style="{StaticResource PrimaryTextBoxStyle}"
                        />
                    <!-- Role Id-->
                    <TextBlock 
                        Text="Role"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,5,0,10"
                        
                        />
                    <ComboBox 
                        Text="RolnamecomboBox"
                        
                        />
                    
                    <!-- Password-->
                    <TextBlock 
                        Text="Password"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,5,0,10"
                        />
                    <TextBox
                        Style="{StaticResource PrimaryTextBoxStyle}"                        
                        />
                    <!-- confirm Password-->
                    <TextBlock 
                        Text="Confirm Password"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Margin="0,5,0,10"                                              
                        />
                    <TextBox
                        Style="{StaticResource PrimaryTextBoxStyle}"
                        />
                    
                    <!-- Register Button-->
                    <Button 
                        Content="Register"
                       Style="{StaticResource PrimaryButtonStyle}"
                        
                        />





                </StackPanel>
            </Grid>
        </Border>
        
    </Grid>
</Window>
